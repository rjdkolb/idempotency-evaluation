# Assertions reference draft-ietf-httpapi-idempotency-key-header-07.

### Test without idempotency
POST {{host}}/orders?delayMillis=100
Idempotency-Key: {{$uuid}}
Content-Type: application/json

{
  "customerOrderReference": "co-{{$timestamp}}"
}



### Idempotent call #1 with 5000 ms delay
< {%
// Generate unique values in script context (template placeholders are not expanded here).
const unique = Date.now() + "-" + Math.floor(Math.random() * 1000000);
client.global.set("idemKeyFromSetup", "idemp-" + unique);
client.global.set("orderRefFromSetup", "orderRef-" + unique);

client.log("setup idemKey=" + client.global.get("idemKeyFromSetup"));
client.log("setup orderRef=" + client.global.get("orderRefFromSetup"));
%}
POST {{host}}/orders/idempotent?delayMillis=5000
Idempotency-Key: {{idemKeyFromSetup}}
Content-Type: application/json

{
  "customerOrderReference": "{{orderRefFromSetup}}"
}

> {%
    client.global.set("firstCustomerOrderReference", response.body.customerOrderReference);
    client.global.set("firstSupplierOrderReference", response.body.supplierOrderReference);

    client.log("call#1 idemKey=" + client.global.get("idemKeyFromSetup"));
    client.log("call#1 customerOrderReference=" + client.global.get("orderRefFromSetup"));
    client.log("call#1 supplierOrderReference=" + client.global.get("firstSupplierOrderReference"));
%}

### Idempotent call #2 while #1 is in flight (same key + same reference)
POST {{host}}/orders/idempotent?delayMillis=0
Idempotency-Key: {{idemKeyFromSetup}}
Content-Type: application/json

{
  "customerOrderReference": "{{orderRefFromSetup}}"
}

> {%
    client.log("call#2 idemKey=" + client.global.get("idemKeyFromSetup"));
    client.log("call#2 customerOrderReference=" + client.global.get("orderRefFromSetup"));
    client.log("call#2 supplierOrderReference=" + client.global.get("firstSupplierOrderReference"));

  client.test("Second call returns same customerOrderReference", function () {
    client.assert(
      response.body.customerOrderReference === client.global.get("firstCustomerOrderReference"),
      "customerOrderReference differs from first call"
    );
  });
%}

### Idempotent call #3 after call #1 and #2 are done (same key + same reference)
POST {{host}}/orders/idempotent
Idempotency-Key: {{idemKeyFromSetup}}
Content-Type: application/json

{
  "customerOrderReference": "{{orderRefFromSetup}}"
}

> {%
  client.test("Third call returns same customerOrderReference", function () {
    client.assert(
      response.body.customerOrderReference === client.global.get("firstCustomerOrderReference"),
      "customerOrderReference differs from first call"
    );
  });

%}


### List all
GET {{host}}/orders


### Missing Idempotency-Key → expect 400 (SHOULD §2.7)
POST {{host}}/orders/idempotent
Content-Type: application/json

{
  "customerOrderReference": "no-key-{{$timestamp}}"
}

> {%
  client.test("Missing Idempotency-Key returns 400 (SHOULD §2.7)", function () {
    client.assert(
      response.status === 400,
      "expected 400 for missing Idempotency-Key, got " + response.status
    );
  });
%}


### Same key, different payload → expect 422 (SHOULD §2.7 / MUST NOT §2.2)
< {%
const unique = Date.now() + "-" + Math.floor(Math.random() * 1000000);
client.global.set("reuseKey", "reuse-" + unique);
client.global.set("reuseRefA", "refA-" + unique);
client.global.set("reuseRefB", "refB-" + unique);
%}
POST {{host}}/orders/idempotent
Idempotency-Key: {{reuseKey}}
Content-Type: application/json

{
  "customerOrderReference": "{{reuseRefA}}"
}

> {%
  client.test("First call succeeds", function () {
    client.assert(response.status === 200, "first call expected 200, got " + response.status);
  });
%}

### Reuse key with a different payload — expect 422
POST {{host}}/orders/idempotent
Idempotency-Key: {{reuseKey}}
Content-Type: application/json

{
  "customerOrderReference": "{{reuseRefB}}"
}

> {%
  client.test("Reused key with different payload returns 422 (SHOULD §2.7)", function () {
    client.assert(
      response.status === 422,
      "expected 422 for reused key with different payload, got " + response.status
    );
  });
%}
